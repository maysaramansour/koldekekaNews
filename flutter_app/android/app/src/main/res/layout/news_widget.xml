<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- App name top-left -->
    <TextView
        android:id="@+id/widget_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:text="كل دقيقة"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:alpha="0.6"
        android:fontFamily="sans-serif" />

    <!-- Time top-right -->
    <TextView
        android:id="@+id/widget_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:text="--"
        android:textColor="#AAFFFFFF"
        android:textSize="10sp" />

    <!-- Source badge -->
    <TextView
        android:id="@+id/widget_source"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_app_name"
        android:layout_alignParentStart="true"
        android:layout_marginTop="6dp"
        android:text="المصدر"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:background="@drawable/widget_source_badge"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp" />

    <!-- Headline — fills remaining space, RTL-friendly -->
    <TextView
        android:id="@+id/widget_headline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_source"
        android:layout_marginTop="6dp"
        android:layout_alignParentBottom="true"
        android:text="جارٍ تحميل الأخبار…"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="3"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.25"
        android:layoutDirection="locale"
        android:textAlignment="viewStart" />

</RelativeLayout>
